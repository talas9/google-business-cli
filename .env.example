# google-business-cli configuration
# Copy to .env and fill in your values. Never commit .env.

# ── Required ─────────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=              # 10 digits, no dashes
GOOGLE_ADS_LOGIN_CUSTOMER_ID=        # MCC manager ID (optional for non-MCC)

# ── Paths (defaults work if repo layout is standard) ─────────
# GADS_PROJECT_ROOT=                 # Parent project root (auto-detected)
# GADS_DB_PATH=                      # SQLite database path
# GADS_CREDENTIALS_PATH=             # OAuth token JSON path
# GADS_SNAPSHOTS_DIR=                # Snapshot output directory

# ── Optional Google services ─────────────────────────────────
# GOOGLE_MERCHANT_CENTER_ID=         # Merchant Center account ID
# GOOGLE_GA4_PROPERTY_ID=            # GA4 property ID (digits only)

# ── Preferences ──────────────────────────────────────────────
# GOOGLE_ADS_API_VERSION=v19         # Google Ads API version
# GADS_TIMEZONE=UTC                  # IANA timezone (e.g. America/New_York, Asia/Dubai)
# GADS_CURRENCY=USD                  # ISO 4217 currency code (e.g. USD, AED, EUR, GBP)

# ── Agent enforcement (optional) ─────────────────────────────
# GADS_ENFORCE_CALLER=1              # Enable caller enforcement
# GADS_EXPECTED_CALLER=google-platform-operator
# GADS_CALLER_AGENT=                 # Set by the calling agent
